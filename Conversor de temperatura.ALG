// Nome do algoritmo
Algoritmo "Conversor de temperaturas"

Var
    celsius, kelvin, fahnhereit : real
    
Inicio
    Escreva("Digite a temperatura em ¤C: ")
    Leia(celsius)
    
    fahnhereit <- (celsius * 1.8) + 32
    kelvin     <- celsius + 273.15

    Escreval("A temperatura em ¤C Õ ",celsius)
    Escreval("A temperatura em ¤F Õ ", fahnhereit)
    Escreval("A temperatura em ¤K Õ ",kelvin)
FimAlgoritmo